NODE_ENV=development
PORT=4000
VIDEO_PORT=4001
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=streamsphere
REDIS_SERVER=localhost
REDIS_PORT=6379

# ── Phase 6: Redis Caching ────────────────────────────────────────────────────
# TTL values (seconds) for each cache layer. Reduce in dev for faster iteration.
CACHE_TTL_FEED=300        # Homepage / trending / recommended video lists
CACHE_TTL_SEARCH=180      # Filtered + paginated search results
CACHE_TTL_DETAIL=120      # Single video detail page
CACHE_TTL_COUNT=300       # Video count queries
CACHE_TTL_STATUS=5        # Transcoding status polling (short to reflect progress)
SERVER_URL=http://localhost:4000
VIDEO_SERVER_URL=http://localhost:4001
UPLOAD_STORAGE=local
ENABLE_WINSTON_MONGODB=false
ENABLE_WINSTON_LOGGLY=false

# JWT Configuration
JWT_SECRET=streamsphere_jwt_secret_key
JWT_EXPIRY=5d

# Optional S3-compatible storage values for later phases.
REGION=us-east-1
ACCESS_KEY=
ACCESS_TOKEN=
ENDPOINT=
BUCKET_NAME=
